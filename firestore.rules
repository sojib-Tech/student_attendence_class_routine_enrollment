rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidCourse() {
      return request.resource.data.keys().hasOnly(['name', 'code']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.code is string &&
        request.resource.data.code.size() > 0;
    }

    function isValidStudent() {
      return request.resource.data.keys().hasOnly(['name', 'studentId']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.studentId is string &&
        request.resource.data.studentId.size() > 0;
    }

    function isValidRoutine() {
      return request.resource.data.keys().hasOnly(['courseId', 'day', 'time']) &&
        request.resource.data.courseId is string &&
        request.resource.data.courseId.size() > 0 &&
        request.resource.data.day is string &&
        request.resource.data.day.size() > 0 &&
        request.resource.data.time is string &&
        request.resource.data.time.size() > 0;
    }

    function isValidAttendance() {
      return request.resource.data.keys().hasOnly(['date', 'records']) &&
        request.resource.data.date is timestamp &&
        request.resource.data.records is map &&
        request.resource.data.records.values().hasOnly(['Present', 'Absent']);
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidCourse();
      allow delete: if isSignedIn();

      match /students/{studentDocId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && isValidStudent();
        allow delete: if isSignedIn();
      }

      match /attendance/{attendanceId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && isValidAttendance();
        allow delete: if isSignedIn();
      }
    }

    match /routine/{routineId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidRoutine();
      allow delete: if isSignedIn();
    }
  }
}

